{
	"name": "checksy",
	"image": "mcr.microsoft.com/devcontainers/base:ubuntu",
	"features": {
		"./features/entr": {},
		"ghcr.io/devcontainers/features/docker-in-docker:2": {
			"moby": false
		},
		"ghcr.io/notwillk/devcontainer-features/devcontainer-cli": {},
		"ghcr.io/notwillk/devcontainer-features/rustup": {},
		"ghcr.io/notwillk/devcontainer-features/just": {}
	},
	"containerEnv": {
		"DEVCONTAINER": "true"
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"github.vscode-github-actions",
				"golang.go",
				"skellock.just",
				"sst-dev.opencode"
			]
		}
	},
	"remoteUser": "vscode"
}
