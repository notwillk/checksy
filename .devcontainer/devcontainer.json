{
	"name": "checksy",
	"image": "mcr.microsoft.com/devcontainers/base:ubuntu",
	"features": {
		"./features/entr": {},
		"ghcr.io/devcontainers/features/docker-in-docker:2": {},
		"ghcr.io/notwillk/devcontainer-features/devcontainer-cli": {},
		"ghcr.io/notwillk/devcontainer-features/rustup": {},
		"ghcr.io/notwillk/devcontainer-features/just": {},
    "ghcr.io/notwillk/devcontainer-features/opencode": {}
	},
	"containerEnv": {
    "DEVCONTAINER": "true",
    "FIREWORKS_API_KEY": "${localEnv:FIREWORKS_API_KEY}",
    "OPENCODE_CONFIG": "${containerWorkspaceFolder}/.opencode/config.json",
		"REPO_PATH": "${containerWorkspaceFolder}"
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"github.vscode-github-actions",
				"golang.go",
				"skellock.just",
				"sst-dev.opencode"
			]
		}
	},
	"remoteUser": "vscode"
}
